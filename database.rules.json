{
  "rules": {
    ".read": false,
    ".write": false,

    "AAAQMS": {
      ".read": "auth != null",

      "hourlyEntries": {
        "$date": {
          "$line": {
            "$hour": {
              "$stage": {
                ".write": "auth != null && newData.exists()"
              }
            }
          }
        }
      },

      "users":               { ".write": "auth != null" },
      "productionLines":     { ".write": "auth != null" },
      "modules":             { ".write": "auth != null" },
      "buyers":              { ".write": "auth != null" },
      "styles":              { ".write": "auth != null" },
      "tasks":               { ".write": "auth != null" },
      "inspectionTemplates": { ".write": "auth != null" },
      "defects":             { ".write": "auth != null" },
      "shifts":              { ".write": "auth != null" },
      "teams":               { ".write": "auth != null" },
      "settings":            { ".write": "auth != null" },
      "appConfig":           { ".write": "auth != null" },
      "reports":             { ".write": "auth != null" },
      "analytics":           { ".write": "auth != null" },
      "notifications":       { ".write": "auth != null" },
      "logs":                { ".write": "auth != null" },
      "dashboardCache":      { ".write": "auth != null" }
    }
  }
}
